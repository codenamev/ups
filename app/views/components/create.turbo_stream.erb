<%# Component Create Turbo Stream %>
<%= turbo_stream.remove "no_components" %>
<%= turbo_stream.append "components_list" do %>
  <%= turbo_frame_tag @component do %>
    <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
      <div class="flex items-center space-x-4">
        <div class="w-3 h-3 rounded-full <%= component_status_color(@component.status) %>"></div>
        <div>
          <h3 class="font-medium text-gray-900"><%= @component.name %></h3>
          <% if @component.description.present? %>
            <p class="text-sm text-gray-600"><%= @component.description %></p>
          <% end %>
        </div>
      </div>
      <div class="flex items-center space-x-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_badge_class(@component.status) %>">
          <%= @component.status.humanize %>
        </span>
        <div class="flex space-x-2">
          <%= link_to "Edit", edit_status_page_component_path(@status_page, @component), 
              class: "text-blue-600 hover:text-blue-800 text-sm font-medium",
              data: { turbo_frame: "component_form" } %>
          <%= button_to "Delete", [@status_page, @component], method: :delete,
              data: { 
                confirm: "Are you sure you want to delete '#{@component.name}'?",
                turbo: true
              },
              class: "text-red-600 hover:text-red-800 text-sm font-medium bg-transparent border-0 p-0" %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
<%= turbo_stream.replace "component_form", "" %>