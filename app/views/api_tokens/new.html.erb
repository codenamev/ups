<div class="min-h-screen bg-gray-50">
  <div class="py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <%= link_to "← Back to API Tokens", api_tokens_path, 
              class: "text-indigo-600 hover:text-indigo-500 text-sm font-medium" %>
      </div>

      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h1 class="text-lg font-medium text-gray-900">Create API Token</h1>
          <p class="mt-1 text-sm text-gray-600">
            Generate a new API token for programmatic access to your account.
          </p>
        </div>

        <%= form_with model: @api_token, local: true, class: "px-6 py-6" do |form| %>
          <% if @api_token.errors.any? %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-md p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800">
                    There were <%= pluralize(@api_token.errors.count, "error") %> with your submission:
                  </h3>
                  <div class="mt-2 text-sm text-red-700">
                    <ul role="list" class="list-disc pl-5 space-y-1">
                      <% @api_token.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div class="space-y-6">
            <div>
              <%= form.label :name, "Token Name", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= form.text_field :name, 
                      placeholder: "e.g., CI/CD Pipeline, Mobile App, Monitoring Script",
                      class: "block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
              </div>
              <p class="mt-2 text-sm text-gray-500">
                Choose a descriptive name to identify what this token is used for.
              </p>
            </div>
          </div>

          <div class="mt-8 bg-yellow-50 border border-yellow-200 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-yellow-800">
                  Important Security Information
                </h3>
                <div class="mt-2 text-sm text-yellow-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>Your token will only be displayed once after creation</li>
                    <li>Store it in a secure location (password manager, environment variable)</li>
                    <li>This token provides full access to your account via API</li>
                    <li>Delete and recreate tokens if they may be compromised</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-8 flex justify-end space-x-3">
            <%= link_to "Cancel", api_tokens_path, 
                  class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
            <%= form.submit "Create Token", 
                  class: "bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 text-white font-medium py-2 px-4 rounded-md" %>
          </div>
        <% end %>
      </div>

      <!-- API Documentation -->
      <div class="mt-8 bg-gray-50 rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">API Documentation</h3>
        <div class="prose prose-sm text-gray-600">
          <p>Your new token will work with all ups.dev API endpoints:</p>
          <div class="mt-4 space-y-3">
            <div>
              <h4 class="font-medium text-gray-900">Status Pages</h4>
              <code class="text-sm bg-gray-100 px-2 py-1 rounded">GET /api/v1/status_pages</code>
            </div>
            <div>
              <h4 class="font-medium text-gray-900">Components</h4>
              <code class="text-sm bg-gray-100 px-2 py-1 rounded">GET /api/v1/status_pages/:id/components</code>
            </div>
            <div>
              <h4 class="font-medium text-gray-900">Incidents</h4>
              <code class="text-sm bg-gray-100 px-2 py-1 rounded">POST /api/v1/status_pages/:id/incidents</code>
            </div>
          </div>
          <p class="mt-4">
            Full API documentation will be available at <code>/docs</code> once your token is created.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>