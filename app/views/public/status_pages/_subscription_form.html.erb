<!-- Subscription Section -->
<div class="bg-white rounded-lg shadow border mt-8" id="subscription-section">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Get Notified</h2>
  </div>
  <div class="px-6 py-6">
    <% if subscriber&.errors&.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <div class="text-sm text-red-700">
              <%= subscriber.errors.full_messages.join(", ") %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    
    <p class="text-gray-600 mb-4">Subscribe to receive email notifications when incidents are reported, updated or resolved.</p>
    <%= form_with(url: public_subscribe_path(status_page.slug), local: true, data: { turbo: true }, class: "flex gap-3") do |form| %>
      <div class="flex-1">
        <%= form.email_field :email, placeholder: "Enter your email address", 
            value: subscriber&.email,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500", 
            required: true %>
      </div>
      <div>
        <%= form.submit "Subscribe", class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
    <% end %>
    <div class="text-xs text-gray-500 mt-2">
      You can unsubscribe at any time. We'll only send notifications for incidents.
    </div>
  </div>
</div>