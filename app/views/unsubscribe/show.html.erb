<!DOCTYPE html>
<html>
  <head>
    <title>Unsubscribe - <%= @subscriber.status_page.name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-50">
    <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-md w-full space-y-8">
        <div class="text-center">
          <h1 class="text-3xl font-extrabold text-gray-900">
            Unsubscribe from Notifications
          </h1>
          <p class="mt-4 text-lg text-gray-600">
            You're about to unsubscribe from notifications for:
          </p>
          <h2 class="mt-2 text-xl font-semibold text-gray-800">
            <%= @subscriber.status_page.name %>
          </h2>
        </div>

        <div class="bg-white shadow-md rounded-lg px-6 py-8">
          <div class="mb-6">
            <p class="text-gray-700 mb-2">
              <strong>Email:</strong> <%= @subscriber.email %>
            </p>
            <p class="text-gray-600 text-sm">
              You will no longer receive incident notifications, updates, or resolution notices for this status page.
            </p>
          </div>

          <%= form_with(url: unsubscribe_confirm_path(@subscriber.unsubscribe_token), method: :post, local: true, class: "space-y-4") do |form| %>
            <div class="flex space-x-4">
              <%= form.submit "Yes, Unsubscribe Me", 
                    class: "flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-md transition duration-200" %>
              
              <%= link_to "Cancel", 
                    public_status_page_path(@subscriber.status_page.slug), 
                    class: "flex-1 bg-gray-300 hover:bg-gray-400 text-gray-700 font-semibold py-2 px-4 rounded-md text-center transition duration-200" %>
            </div>
          <% end %>
        </div>

        <div class="text-center">
          <p class="text-sm text-gray-500">
            You can re-subscribe at any time by visiting the
            <%= link_to "status page", public_status_page_path(@subscriber.status_page.slug), 
                  class: "text-blue-600 hover:text-blue-500" %>.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>