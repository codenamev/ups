<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="text-center">
      <div class="mx-auto h-12 w-12 text-green-500">
        <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 48 48">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        Successfully unsubscribed
      </h2>
    </div>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <div class="text-center">
        <div class="mb-6">
          <p class="text-gray-600 mb-4">
            You have been successfully unsubscribed from notifications for:
          </p>
          <p class="text-lg font-medium text-gray-900 mb-2">
            <%= @status_page.name %>
          </p>
          <p class="text-sm text-gray-500">
            Email: <%= @subscriber.email %>
          </p>
        </div>

        <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
          <p class="text-sm text-green-700">
            You will no longer receive email notifications for this status page. 
            If you change your mind, you can always resubscribe by visiting the status page.
          </p>
        </div>

        <div class="space-y-3">
          <a href="<%= public_status_page_url(@status_page.slug) %>" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-md text-sm font-medium inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
            View Status Page
          </a>
        </div>
      </div>
    </div>
  </div>
</div>