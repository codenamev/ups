<% if @incident.components.any? %>
Previously Affected Components:
<% @incident.components.each do |component| %>
- <%= component.name %>: <%= component.status.humanize %>
<% end %>

<% end %>
Duration: <% if @incident.started_at.present? && @incident.resolved_at.present? %>
<%= time_ago_in_words(@incident.resolved_at, @incident.started_at) %>
<% else %>
Unknown
<% end %>

Started: <%= @incident.started_at.strftime("%B %d, %Y at %l:%M %p %Z") %>
Resolved: <%= @incident.resolved_at.strftime("%B %d, %Y at %l:%M %p %Z") if @incident.resolved_at.present? %>

