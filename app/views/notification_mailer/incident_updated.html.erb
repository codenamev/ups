<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style type="text/css">
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; }
      .header { background: #f8f9fa; padding: 20px; border-bottom: 3px solid #fd7e14; }
      .content { padding: 20px; }
      .incident-badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; text-transform: uppercase; }
      .incident-badge.critical { background: #dc3545; color: white; }
      .incident-badge.major { background: #fd7e14; color: white; }
      .incident-badge.minor { background: #ffc107; color: #000; }
      .incident-badge.maintenance { background: #6c757d; color: white; }
      .status-badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; text-transform: uppercase; }
      .status-badge.investigating { background: #dc3545; color: white; }
      .status-badge.identified { background: #fd7e14; color: white; }
      .status-badge.monitoring { background: #ffc107; color: #000; }
      .status-badge.resolved { background: #28a745; color: white; }
      .components { margin: 20px 0; }
      .component { padding: 8px 0; border-bottom: 1px solid #eee; }
      .footer { background: #f8f9fa; padding: 15px; font-size: 12px; color: #6c757d; border-top: 1px solid #dee2e6; }
      .button { display: inline-block; padding: 12px 24px; background: #007bff; color: white; text-decoration: none; border-radius: 4px; }
      .unsubscribe { color: #6c757d; font-size: 11px; }
    </style>
  </head>
  <body>
    <div class="header">
      <h1><%= @status_page.name %></h1>
      <h2>📢 Incident Update</h2>
    </div>

    <div class="content">
      <h3><%= @incident.title %></h3>
      
      <p>
        <span class="incident-badge <%= @incident.impact %>"><%= @incident.impact.humanize %> Impact</span>
        <span class="status-badge <%= @incident.status %>"><%= @incident.status.humanize %></span>
      </p>

      <% if @incident.description.present? %>
        <div style="background: #f8f9fa; padding: 15px; border-radius: 4px; margin: 15px 0;">
          <%= simple_format(@incident.description) %>
        </div>
      <% end %>

      <% if @incident.components.any? %>
        <div class="components">
          <h4>Affected Components:</h4>
          <% @incident.components.each do |component| %>
            <div class="component">
              <strong><%= component.name %></strong>
              <span style="color: #6c757d;">- <%= component.status.humanize %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @incident.incident_updates.any? %>
        <div style="margin: 20px 0;">
          <h4>Latest Updates:</h4>
          <% @incident.incident_updates.limit(3).each do |update| %>
            <div style="background: #fff; border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; margin: 10px 0;">
              <div style="font-size: 12px; color: #6c757d; margin-bottom: 5px;">
                <%= update.created_at.strftime("%B %d, %Y at %l:%M %p %Z") %>
              </div>
              <%= simple_format(update.body) if update.respond_to?(:body) && update.body.present? %>
            </div>
          <% end %>
        </div>
      <% end %>

      <p><strong>Started:</strong> <%= @incident.started_at.strftime("%B %d, %Y at %l:%M %p %Z") %></p>

      <p style="margin-top: 30px;">
        <a href="<%= status_page_url(@status_page) %>" class="button">View Status Page</a>
      </p>
    </div>

    <div class="footer">
      <p>You're receiving this because you're subscribed to <%= @status_page.name %> status updates.</p>
      <p class="unsubscribe">
        <a href="<%= @unsubscribe_url %>">Unsubscribe from all notifications</a>
      </p>
    </div>
  </body>
</html>