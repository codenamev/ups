<%# Edit Status Page %>
<div class="max-w-2xl">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Edit Status Page</h1>
    <p class="text-gray-600 mt-2">Update your status page settings and information.</p>
  </div>

  <%= form_with model: @status_page, local: true, class: "space-y-6" do |form| %>
    <% if @status_page.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              There were <%= pluralize(@status_page.errors.count, "error") %> with your submission:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside space-y-1">
                <% @status_page.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
      <p class="mt-2 text-sm text-gray-500">A clear name for your status page that users will see.</p>
    </div>

    <div>
      <%= form.label :slug, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :slug, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
      <p class="mt-2 text-sm text-gray-500">
        This is your status page URL: 
        <code class="bg-gray-100 px-1 py-0.5 rounded text-sm"><%= request.base_url %>/<span id="slug-preview"><%= @status_page.slug %></span></code>
      </p>
      <div class="mt-2 p-3 bg-yellow-50 border border-yellow-200 rounded-md">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-yellow-700">
              <strong>Warning:</strong> Changing the slug will break existing bookmarks and links to your status page.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
      <p class="mt-2 text-sm text-gray-500">Optional description that will appear on your status page.</p>
    </div>

    <div class="flex justify-between pt-6 border-t">
      <div>
        <%= link_to "Cancel", @status_page, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        <%= form.submit "Update Status Page", class: "ml-3 px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
      <%= button_to "Delete Status Page", @status_page, method: :delete, 
            data: { 
              confirm: "Are you sure you want to delete '#{@status_page.name}'? This action cannot be undone and will delete all components and incidents." 
            },
            class: "px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-md shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const slugField = document.getElementById('status_page_slug');
  const slugPreview = document.getElementById('slug-preview');
  
  function updatePreview() {
    slugPreview.textContent = slugField.value || 'your-slug';
  }
  
  slugField.addEventListener('input', updatePreview);
});
</script>