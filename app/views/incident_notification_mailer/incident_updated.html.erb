<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Incident Update: <%= @incident.title %></title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        border-bottom: 2px solid #e5e7eb;
        margin-bottom: 20px;
        padding-bottom: 20px;
      }
      .incident {
        background-color: #fef2f2;
        border-left: 4px solid #ef4444;
        padding: 16px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .incident.major {
        background-color: #fef3c7;
        border-left-color: #f59e0b;
      }
      .incident.critical {
        background-color: #fef2f2;
        border-left-color: #dc2626;
      }
      .incident.maintenance {
        background-color: #f0f9ff;
        border-left-color: #3b82f6;
      }
      .update {
        background-color: #f0f9ff;
        border: 1px solid #93c5fd;
        padding: 16px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .status-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
      }
      .status-investigating {
        background-color: #fef3c7;
        color: #92400e;
      }
      .status-identified {
        background-color: #fed7d7;
        color: #9b2c2c;
      }
      .status-monitoring {
        background-color: #e6fffa;
        color: #285e61;
      }
      .status-resolved {
        background-color: #f0fff4;
        color: #276749;
      }
      .impact-minor { color: #059669; }
      .impact-major { color: #d97706; }
      .impact-critical { color: #dc2626; }
      .impact-maintenance { color: #3b82f6; }
      .components {
        margin: 16px 0;
      }
      .component {
        background-color: #f9fafb;
        padding: 8px 12px;
        margin: 4px 0;
        border-radius: 4px;
        font-size: 14px;
      }
      .footer {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
        font-size: 12px;
        color: #6b7280;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background-color: #3b82f6;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        margin: 16px 0;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1><%= @status_page.name %></h1>
      <p>An incident has been updated</p>
    </div>

    <div class="update">
      <h3>Latest Update</h3>
      <p><strong>Posted:</strong> <%= @incident_update.created_at.strftime("%B %d, %Y at %I:%M %p %Z") %></p>
      <% if @incident_update.message.present? %>
        <p><%= simple_format(@incident_update.message) %></p>
      <% end %>
    </div>

    <div class="incident <%= @incident.impact %>">
      <h2><%= @incident.title %></h2>
      
      <p>
        <strong>Current Status:</strong> 
        <span class="status-badge status-<%= @incident.status.downcase %>">
          <%= @incident.status.humanize %>
        </span>
      </p>
      
      <p>
        <strong>Impact:</strong> 
        <span class="impact-<%= @incident.impact %>">
          <%= @incident.impact.humanize %>
        </span>
      </p>

      <% if @incident.components.any? %>
        <div class="components">
          <strong>Affected Components:</strong>
          <% @incident.components.each do |component| %>
            <div class="component">
              <%= component.name %> - <span class="status-<%= component.status %>"><%= component.status.humanize %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <p><strong>Started:</strong> <%= @incident.started_at.strftime("%B %d, %Y at %I:%M %p %Z") %></p>
      <% if @incident.resolved_at %>
        <p><strong>Resolved:</strong> <%= @incident.resolved_at.strftime("%B %d, %Y at %I:%M %p %Z") %></p>
      <% end %>
    </div>

    <a href="<%= status_page_url(@status_page) %>" class="btn">
      View Status Page
    </a>

    <div class="footer">
      <p>
        You're receiving this notification because you subscribed to updates from <%= @status_page.name %>.
      </p>
      <p>
        <a href="<%= @unsubscribe_url %>">Unsubscribe from these notifications</a>
      </p>
    </div>
  </body>
</html>