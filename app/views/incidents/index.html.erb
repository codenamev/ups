<%
  title = "Incidents"
  breadcrumbs = [
    { text: "Dashboard", path: dashboard_path },
    { text: title, path: incidents_path }
  ]
%>

<div class="header-controls flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="text-gray-600 mt-1">Manage incidents and track their lifecycle.</p>
  </div>
  
  <div class="flex items-center gap-3">
    <div class="relative">
      <select onchange="this.form.submit()" name="status_page" class="form-select">
        <option value="">All Status Pages</option>
        <% Current.account.status_pages.each do |sp| %>
          <option value="<%= sp.id %>" <%= "selected" if params[:status_page] == sp.id.to_s %>>
            <%= sp.name %>
          </option>
        <% end %>
      </select>
    </div>
    
    <%= link_to "New Incident", new_status_page_incident_path(Current.account.status_pages.first),
        class: "btn-primary" %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-6 border">
    <div class="flex items-center">
      <div class="p-3 rounded-full bg-red-100 text-red-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.996-.833-2.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm text-gray-600">Active Incidents</p>
        <p class="text-2xl font-bold text-gray-900"><%= @incidents.active.count %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6 border">
    <div class="flex items-center">
      <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm text-gray-600">Investigating</p>
        <p class="text-2xl font-bold text-gray-900"><%= @incidents.status_investigating.count %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6 border">
    <div class="flex items-center">
      <div class="p-3 rounded-full bg-blue-100 text-blue-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm text-gray-600">Monitoring</p>
        <p class="text-2xl font-bold text-gray-900"><%= @incidents.status_monitoring.count %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6 border">
    <div class="flex items-center">
      <div class="p-3 rounded-full bg-green-100 text-green-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm text-gray-600">This Month</p>
        <p class="text-2xl font-bold text-gray-900"><%= @incidents.where(created_at: 30.days.ago..).count %></p>
      </div>
    </div>
  </div>
</div>

<!-- Incidents List -->
<div class="bg-white rounded-lg shadow border overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Recent Incidents</h2>
  </div>

  <% if @incidents.any? %>
    <div class="divide-y divide-gray-200">
      <% @incidents.each do |incident| %>
        <div class="px-6 py-4 hover:bg-gray-50 transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-semibold text-gray-900 text-base">
                  <%= link_to incident.title, status_page_incident_path(incident.status_page, incident), 
                      class: "hover:text-blue-600" %>
                </h3>
                
                <!-- Status Badge -->
                <% status_class = case incident.status
                   when "investigating" then "bg-yellow-100 text-yellow-800"
                   when "identified" then "bg-orange-100 text-orange-800"  
                   when "monitoring" then "bg-blue-100 text-blue-800"
                   when "resolved" then "bg-green-100 text-green-800"
                   end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
                  <%= incident.status.humanize %>
                </span>
                
                <!-- Impact Badge -->
                <% impact_class = case incident.impact
                   when "minor" then "bg-gray-100 text-gray-800"
                   when "major" then "bg-orange-100 text-orange-800" 
                   when "critical" then "bg-red-100 text-red-800"
                   when "maintenance" then "bg-blue-100 text-blue-800"
                   end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= impact_class %>">
                  <%= incident.impact.humanize %> Impact
                </span>
              </div>
              
              <% if incident.description.present? %>
                <p class="text-sm text-gray-600 mb-2"><%= truncate(incident.description, length: 150) %></p>
              <% end %>
              
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span>
                  <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <%= incident.user.name %>
                </span>
                
                <span>
                  <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= time_ago_in_words(incident.created_at) %> ago
                </span>
                
                <span>
                  <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
                  </svg>
                  <%= incident.incident_updates.count %> updates
                </span>
                
                <% if incident.components.any? %>
                  <span>
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                    <%= incident.components.count %> components
                  </span>
                <% end %>
              </div>
            </div>
            
            <div class="flex items-center gap-2 ml-4">
              <%= link_to "View", status_page_incident_path(incident.status_page, incident),
                  class: "btn-sm btn-secondary" %>
              <%= link_to "Edit", edit_status_page_incident_path(incident.status_page, incident),
                  class: "btn-sm btn-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <div class="text-gray-400 mb-4">
        <svg class="h-16 w-16 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0121 12a8 8 0 10-8 8 7.962 7.962 0 015.291-2M15 8a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No Incidents Found</h3>
      <p class="text-gray-600 mb-4">Great news! No incidents have been reported recently.</p>
      <%= link_to "Create First Incident", new_status_page_incident_path(Current.account.status_pages.first),
          class: "btn-primary" %>
    </div>
  <% end %>
</div>