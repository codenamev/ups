<% if incident_updates.any? %>
  <div class="divide-y divide-gray-200">
    <% incident_updates.each do |update| %>
      <div class="p-6" id="update-<%= update.id %>">
        <div class="flex items-start justify-between">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-semibold text-gray-900"><%= update.title %></h3>
              
              <% if update.status.present? %>
                <% status_class = case update.status
                   when "investigating" then "bg-yellow-100 text-yellow-800"
                   when "identified" then "bg-orange-100 text-orange-800"  
                   when "monitoring" then "bg-blue-100 text-blue-800"
                   when "resolved" then "bg-green-100 text-green-800"
                   end %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
                  Status: <%= update.status.humanize %>
                </span>
              <% end %>
            </div>
            
            <div class="prose prose-sm max-w-none text-gray-700 mb-3">
              <%= simple_format(update.content) %>
            </div>
            
            <div class="flex items-center gap-4 text-xs text-gray-500">
              <span>
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Posted by <%= update.user.name %>
              </span>
              
              <span>
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= update.created_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
              </span>
            </div>
          </div>
          
          <div class="flex items-center gap-2 ml-4">
            <%= link_to "Edit", edit_status_page_incident_incident_update_path(incident.status_page, incident, update),
                class: "text-sm text-blue-600 hover:text-blue-800" %>
            <%= link_to "Delete", status_page_incident_incident_update_path(incident.status_page, incident, update),
                method: :delete,
                class: "text-sm text-red-600 hover:text-red-800",
                data: { confirm: "Are you sure?" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="p-6 text-center">
    <div class="text-gray-400 mb-4">
      <svg class="h-12 w-12 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
      </svg>
    </div>
    <h3 class="text-lg font-medium text-gray-900 mb-2">No Updates Yet</h3>
    <p class="text-gray-600 mb-4">Post the first update to keep stakeholders informed.</p>
    <%= link_to "Post Update", new_status_page_incident_incident_update_path(incident.status_page, incident),
        class: "btn-primary" %>
  </div>
<% end %>