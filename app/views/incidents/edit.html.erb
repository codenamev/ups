<%
  title = "Edit Incident"
  breadcrumbs = [
    { text: "Dashboard", path: dashboard_path },
    { text: "Incidents", path: incidents_path },
    { text: @incident.title, path: status_page_incident_path(@incident.status_page, @incident) },
    { text: title, path: edit_status_page_incident_path(@incident.status_page, @incident) }
  ]
%>

<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="text-gray-600 mt-1">Update incident details and affected components.</p>
  </div>

  <%= form_with model: [@incident.status_page, @incident], local: true, class: "space-y-6" do |form| %>
    <% if @incident.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@incident.errors.count, "error") %> prohibited this incident from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul role="list" class="list-disc space-y-1 pl-5">
                <% @incident.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="bg-white rounded-lg shadow border">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Incident Details</h2>
      </div>
      
      <div class="p-6 space-y-6">
        <!-- Status Page (read-only) -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Status Page</label>
          <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
            <%= @incident.status_page.name %>
          </div>
          <p class="mt-1 text-xs text-gray-500">The status page cannot be changed after incident creation.</p>
        </div>

        <!-- Title -->
        <div>
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :title, 
              class: "form-input", 
              placeholder: "Brief description of the incident",
              required: true %>
          <p class="mt-1 text-xs text-gray-500">A concise title that describes the incident.</p>
        </div>

        <!-- Description -->
        <div>
          <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_area :description, 
              class: "form-textarea",
              rows: 4,
              placeholder: "Detailed description of what's happening, potential impact, and investigation findings" %>
          <p class="mt-1 text-xs text-gray-500">Provide context and details about the incident.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Status -->
          <div>
            <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.select :status, 
                options_for_select([
                  ["Investigating", "investigating"],
                  ["Identified", "identified"],
                  ["Monitoring", "monitoring"],
                  ["Resolved", "resolved"]
                ], @incident.status),
                {},
                { class: "form-select", required: true } %>
            <p class="mt-1 text-xs text-gray-500">Current status of the incident investigation.</p>
          </div>

          <!-- Impact -->
          <div>
            <%= form.label :impact, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.select :impact, 
                options_for_select([
                  ["Minor", "minor"],
                  ["Major", "major"],
                  ["Critical", "critical"],
                  ["Maintenance", "maintenance"]
                ], @incident.impact),
                {},
                { class: "form-select", required: true } %>
            <p class="mt-1 text-xs text-gray-500">Severity of the impact on services.</p>
          </div>
        </div>

        <!-- Components Affected -->
        <% if @available_components.any? %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3">Affected Components</label>
            <div class="space-y-2">
              <% current_component_ids = @incident.components.pluck(:id) %>
              <% @available_components.each do |component| %>
                <div class="flex items-center">
                  <%= check_box_tag "component_ids[]", component.id, current_component_ids.include?(component.id), 
                      id: "component_#{component.id}", 
                      class: "form-checkbox" %>
                  <%= label_tag "component_#{component.id}", component.name, 
                      class: "ml-2 text-sm text-gray-700" %>
                </div>
              <% end %>
            </div>
            <p class="mt-2 text-xs text-gray-500">Select all components that are affected by this incident.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Timeline Information -->
    <div class="bg-white rounded-lg shadow border">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Timeline</h2>
      </div>
      
      <div class="p-6 space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Started At</label>
            <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
              <%= @incident.started_at&.strftime("%B %d, %Y at %I:%M %p UTC") || @incident.created_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
            </div>
          </div>
          
          <% if @incident.resolved_at.present? %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Resolved At</label>
              <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
                <%= @incident.resolved_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
              </div>
            </div>
          <% end %>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Created By</label>
          <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
            <%= @incident.user.name %> on <%= @incident.created_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between pt-6">
      <%= link_to "Cancel", status_page_incident_path(@incident.status_page, @incident), 
          class: "btn-secondary" %>
      
      <div class="flex items-center gap-3">
        <% unless @incident.status_resolved? %>
          <%= link_to "Mark as Resolved", 
              status_page_incident_path(@incident.status_page, @incident, incident: { status: "resolved" }), 
              method: :patch,
              class: "btn-success",
              data: { confirm: "Are you sure you want to mark this incident as resolved?" } %>
        <% end %>
        
        <%= form.submit "Update Incident", 
            class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</div>