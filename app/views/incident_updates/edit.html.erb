<%
  title = "Edit Incident Update"
  breadcrumbs = [
    { text: "Dashboard", path: dashboard_path },
    { text: "Incidents", path: incidents_path },
    { text: @incident.title, path: status_page_incident_path(@incident.status_page, @incident) },
    { text: title, path: edit_status_page_incident_incident_update_path(@incident.status_page, @incident, @incident_update) }
  ]
%>

<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="text-gray-600 mt-1">Edit this incident update.</p>
  </div>

  <!-- Incident Context -->
  <div class="bg-blue-50 border border-blue-200 rounded-md p-4 mb-6">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-blue-800">Incident: <%= @incident.title %></h3>
        <div class="mt-2 text-sm text-blue-700">
          <div class="flex items-center gap-4">
            <span>Status: <%= @incident.status.humanize %></span>
            <span>Impact: <%= @incident.impact.humanize %></span>
            <span>Update posted: <%= time_ago_in_words(@incident_update.created_at) %> ago</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= form_with model: [@incident.status_page, @incident, @incident_update], local: true, class: "space-y-6" do |form| %>
    <% if @incident_update.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@incident_update.errors.count, "error") %> prohibited this update from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul role="list" class="list-disc space-y-1 pl-5">
                <% @incident_update.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="bg-white rounded-lg shadow border">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Update Details</h2>
      </div>
      
      <div class="p-6 space-y-6">
        <!-- Title -->
        <div>
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :title, 
              class: "form-input", 
              placeholder: "Brief summary of this update",
              required: true %>
          <p class="mt-1 text-xs text-gray-500">A short title that summarizes what's in this update.</p>
        </div>

        <!-- Content -->
        <div>
          <%= form.label :content, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_area :content, 
              class: "form-textarea",
              rows: 6,
              placeholder: "Provide a detailed update about the incident status, what actions have been taken, next steps, and any relevant information for stakeholders.",
              required: true %>
          <p class="mt-1 text-xs text-gray-500">Detailed information about the current situation and actions being taken.</p>
        </div>

        <!-- Status (read-only for edits) -->
        <% if @incident_update.status.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status Change</label>
            <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
              This update changed the incident status to: <%= @incident_update.status.humanize %>
            </div>
            <p class="mt-1 text-xs text-gray-500">Status changes cannot be modified after posting. Create a new update to change status again.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Metadata -->
    <div class="bg-white rounded-lg shadow border">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Update Information</h2>
      </div>
      
      <div class="p-6 space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Originally Posted</label>
            <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
              <%= @incident_update.created_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Posted By</label>
            <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-700">
              <%= @incident_update.user.name %>
            </div>
          </div>
        </div>
        
        <% if @incident_update.updated_at != @incident_update.created_at %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last Modified</label>
            <div class="px-3 py-2 bg-yellow-50 border border-yellow-200 rounded-md text-sm text-yellow-800">
              <%= @incident_update.updated_at.strftime("%B %d, %Y at %I:%M %p UTC") %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between pt-6">
      <%= link_to "Cancel", status_page_incident_path(@incident.status_page, @incident), 
          class: "btn-secondary" %>
      
      <div class="flex items-center gap-3">
        <%= link_to "Delete Update", 
            status_page_incident_incident_update_path(@incident.status_page, @incident, @incident_update),
            method: :delete,
            class: "btn-danger",
            data: { confirm: "Are you sure you want to delete this update? This action cannot be undone." } %>
        
        <%= form.submit "Save Changes", 
            class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</div>