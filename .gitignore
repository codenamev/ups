# Ignore bundler config.
/.bundle

# Ignore all environment files.
.env*

# Ignore the default SQLite database.
/storage/*.sqlite3
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (file uploads, Active Storage, etc).
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore Kamal secrets
/.kamal/secrets

# Ignore node modules
/node_modules

# Ignore assets builds
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore CI artifacts
/coverage
/vendor/bundle
